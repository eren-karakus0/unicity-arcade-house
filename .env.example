# ============================================================
#  Sphere Agent Bazaar — environment template
#  Copy to .env and fill in. The .env file is gitignored.
# ============================================================

# ---- Unicity Sphere network (testnet2) ----
# 'testnet' IS testnet2 (the v2 gateway). mainnet/dev are v1-era and won't serve v2.
SPHERE_NETWORK=testnet
# The testnet2 gateway key is PUBLIC (not a secret) — safe to keep here.
SPHERE_ORACLE_API_KEY=sk_ddc3cfcc001e4a28ac3fad7407f99590
SPHERE_WALLET_API_URL=https://wallet-api.unicity.network

# ---- Agent identities (on-network @nametags) ----
ANALYST_NAMETAG=analyst-knkchn
ALPHASCOUT_NAMETAG=alphascout-knkchn

# ---- Agent mnemonics ----
# Leave EMPTY to auto-generate on first run; then paste the printed phrases
# back here to keep stable identities across restarts.
# NEVER commit a real mnemonic — it belongs only in your local .env.
ANALYST_MNEMONIC=
ALPHASCOUT_MNEMONIC=

# ---- LLM (OPTIONAL — templated fallback is used if unset) ----
# Free key from https://aistudio.google.com  (kept ONLY here, never committed).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ---- Free data sources (no key required: GitHub public API, OSV.dev) ----
# Optional GitHub token only raises rate limits.
GITHUB_TOKEN=
